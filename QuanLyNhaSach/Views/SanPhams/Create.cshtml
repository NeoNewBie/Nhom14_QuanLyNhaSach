@model QuanLyNhaSach.Models.SanPham

@{
	ViewData["Title"] = "Thêm sản phẩm mới";
}

<div class="container mt-4">
	<div class="row">
		<div class="col-md-8 offset-md-2">
			<h1>@ViewData["Title"]</h1>
			<hr />

			<form asp-action="Create">
				<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

				<div class="mb-3">
					<label asp-for="TenSanPham" class="form-label"></label>
					<input asp-for="TenSanPham" class="form-control" />
					<span asp-validation-for="TenSanPham" class="text-danger"></span>
				</div>

				<div class="mb-3">
					<label asp-for="MoTa" class="form-label"></label>
					<textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
					<span asp-validation-for="MoTa" class="text-danger"></span>
				</div>

				<div class="row">
					<div class="col-md-6 mb-3">
						<label asp-for="GiaBia" class="form-label"></label>
						<input asp-for="GiaBia" class="form-control" type="number" step="0.01" />
						<span asp-validation-for="GiaBia" class="text-danger"></span>
					</div>
					<div class="col-md-6 mb-3">
						<label asp-for="GiaNhap" class="form-label"></label>
						<input asp-for="GiaNhap" class="form-control" type="number" step="0.01" />
						<span asp-validation-for="GiaNhap" class="text-danger"></span>
					</div>
				</div>

				<div class="row">
					<div class="col-md-6 mb-3">
						<label asp-for="GiaBan" class="form-label"></label>
						<input asp-for="GiaBan" class="form-control" type="number" step="0.01" />
						<span asp-validation-for="GiaBan" class="text-danger"></span>
					</div>
					<div class="col-md-6 mb-3">
						<label asp-for="SoLuongTon" class="form-label"></label>
						<input asp-for="SoLuongTon" class="form-control" type="number" />
						<span asp-validation-for="SoLuongTon" class="text-danger"></span>
					</div>
				</div>

				<div class="row">
					<div class="col-md-6 mb-3">
						<label asp-for="LoaiSanPham" class="form-label"></label>
						<input asp-for="LoaiSanPham" class="form-control" />
						<span asp-validation-for="LoaiSanPham" class="text-danger"></span>
					</div>
					<div class="col-md-6 mb-3">
						<label asp-for="AnhBia" class="form-label"></label>
						<input asp-for="AnhBia" class="form-control" />
						<span asp-validation-for="AnhBia" class="text-danger"></span>
					</div>
				</div>

				<div class="row">
					<div class="col-md-6 mb-3">
						<label asp-for="MaDanhMuc" class="form-label"></label>
						<input asp-for="MaDanhMuc" class="form-control" type="number" />
						<span asp-validation-for="MaDanhMuc" class="text-danger"></span>
					</div>
					<div class="col-md-6 mb-3">
						<label asp-for="MaNhaXuatBan" class="form-label"></label>
						<input asp-for="MaNhaXuatBan" class="form-control" type="number" />
						<span asp-validation-for="MaNhaXuatBan" class="text-danger"></span>
					</div>
				</div>

				<div class="mb-3 form-check">
					<input type="checkbox" asp-for="TrangThai" class="form-check-input" />
					<label asp-for="TrangThai" class="form-check-label"></label>
					<span asp-validation-for="TrangThai" class="text-danger"></span>
				</div>

				<div class="mb-3">
					<label asp-for="NgayTao" class="form-label"></label>
					<input asp-for="NgayTao" class="form-control" type="datetime-local" />
					<span asp-validation-for="NgayTao" class="text-danger"></span>
				</div>

				<div class="form-group mt-4">
					<button type="submit" class="btn btn-success">
						<i class="bi bi-check-circle"></i> Thêm mới
					</button>
					<a asp-action="Index" class="btn btn-secondary">
						<i class="bi bi-x-circle"></i> Hủy
					</a>
				</div>
			</form>
		</div>
	</div>
</div>

@section Scripts {
	@{
		await Html.RenderPartialAsync("_ValidationScriptsPartial");
	}
}
