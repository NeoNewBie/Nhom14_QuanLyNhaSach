@model QuanLyNhaSach.Models.SanPham

@{
	ViewData["Title"] = "Chi tiết sản phẩm";
}

<div class="container mt-4">
	<div class="row">
		<div class="col-md-8 offset-md-2">
			<h1>@ViewData["Title"]</h1>
			<hr />

			<div class="card">
				<div class="card-body">
					<dl class="row">
						<dt class="col-sm-3">
							<label asp-for="MaSanPham"></label>
						</dt>
						<dd class="col-sm-9">
							@Html.DisplayFor(model => model.MaSanPham)
						</dd>

						<dt class="col-sm-3">
							<label asp-for="TenSanPham"></label>
						</dt>
						<dd class="col-sm-9">
							@Html.DisplayFor(model => model.TenSanPham)
						</dd>

						<dt class="col-sm-3">
							<label asp-for="MoTa"></label>
						</dt>
						<dd class="col-sm-9">
							@Html.DisplayFor(model => model.MoTa)
						</dd>

						<dt class="col-sm-3">
							<label asp-for="GiaBia"></label>
						</dt>
						<dd class="col-sm-9">
							@Html.DisplayFor(model => model.GiaBia)
						</dd>

						<dt class="col-sm-3">
							<label asp-for="GiaNhap"></label>
						</dt>
						<dd class="col-sm-9">
							@Html.DisplayFor(model => model.GiaNhap)
						</dd>

						<dt class="col-sm-3">
							<label asp-for="GiaBan"></label>
						</dt>
						<dd class="col-sm-9">
							@Html.DisplayFor(model => model.GiaBan)
						</dd>

						<dt class="col-sm-3">
							<label asp-for="SoLuongTon"></label>
						</dt>
						<dd class="col-sm-9">
							@Html.DisplayFor(model => model.SoLuongTon)
						</dd>

						<dt class="col-sm-3">
							<label asp-for="AnhBia"></label>
						</dt>
						<dd class="col-sm-9">
							@Html.DisplayFor(model => model.AnhBia)
						</dd>

						<dt class="col-sm-3">
							<label asp-for="LoaiSanPham"></label>
						</dt>
						<dd class="col-sm-9">
							@Html.DisplayFor(model => model.LoaiSanPham)
						</dd>

						<dt class="col-sm-3">
							<label asp-for="MaDanhMuc"></label>
						</dt>
						<dd class="col-sm-9">
							@Html.DisplayFor(model => model.MaDanhMuc)
						</dd>

						<dt class="col-sm-3">
							<label asp-for="MaNhaXuatBan"></label>
						</dt>
						<dd class="col-sm-9">
							@Html.DisplayFor(model => model.MaNhaXuatBan)
						</dd>

						<dt class="col-sm-3">
							<label asp-for="TrangThai"></label>
						</dt>
						<dd class="col-sm-9">
							@if (Model.TrangThai)
							{
								<span class="badge bg-success">Hoạt động</span>
							}
							else
							{
								<span class="badge bg-danger">Không hoạt động</span>
							}
						</dd>

						<dt class="col-sm-3">
							<label asp-for="NgayTao"></label>
						</dt>
						<dd class="col-sm-9">
							@Html.DisplayFor(model => model.NgayTao)
						</dd>
					</dl>
				</div>
			</div>

			<div class="mt-4">
				<a asp-action="Edit" asp-route-id="@Model.MaSanPham" class="btn btn-warning">
					<i class="bi bi-pencil"></i> Chỉnh sửa
				</a>
				<a asp-action="Delete" asp-route-id="@Model.MaSanPham" class="btn btn-danger">
					<i class="bi bi-trash"></i> Xóa
				</a>
				<a asp-action="Index" class="btn btn-secondary">
					<i class="bi bi-arrow-left"></i> Quay lại
				</a>
			</div>
		</div>
	</div>
</div>
