@model QuanLyNhaSach.Models.SanPham

@{
	ViewData["Title"] = "Xóa sản phẩm";
}

<div class="container mt-4">
	<div class="row">
		<div class="col-md-8 offset-md-2">
			<h1 class="text-danger">@ViewData["Title"]</h1>
			<hr />

			<div class="alert alert-warning" role="alert">
				<i class="bi bi-exclamation-triangle"></i> 
				Bạn có chắc chắn muốn xóa sản phẩm <strong>@Model.TenSanPham</strong>? 
				Hành động này không thể hoàn tác.
			</div>

			<dl class="row">
				<dt class="col-sm-3">
					<label asp-for="MaSanPham"></label>
				</dt>
				<dd class="col-sm-9">
					@Html.DisplayFor(model => model.MaSanPham)
				</dd>

				<dt class="col-sm-3">
					<label asp-for="TenSanPham"></label>
				</dt>
				<dd class="col-sm-9">
					@Html.DisplayFor(model => model.TenSanPham)
				</dd>

				<dt class="col-sm-3">
					<label asp-for="MoTa"></label>
				</dt>
				<dd class="col-sm-9">
					@Html.DisplayFor(model => model.MoTa)
				</dd>

				<dt class="col-sm-3">
					<label asp-for="GiaBia"></label>
				</dt>
				<dd class="col-sm-9">
					@Html.DisplayFor(model => model.GiaBia)
				</dd>

				<dt class="col-sm-3">
					<label asp-for="GiaBan"></label>
				</dt>
				<dd class="col-sm-9">
					@Html.DisplayFor(model => model.GiaBan)
				</dd>

				<dt class="col-sm-3">
					<label asp-for="SoLuongTon"></label>
				</dt>
				<dd class="col-sm-9">
					@Html.DisplayFor(model => model.SoLuongTon)
				</dd>

				<dt class="col-sm-3">
					<label asp-for="LoaiSanPham"></label>
				</dt>
				<dd class="col-sm-9">
					@Html.DisplayFor(model => model.LoaiSanPham)
				</dd>

				<dt class="col-sm-3">
					<label asp-for="TrangThai"></label>
				</dt>
				<dd class="col-sm-9">
					@if (Model.TrangThai)
					{
						<span class="badge bg-success">Hoạt động</span>
					}
					else
					{
						<span class="badge bg-danger">Không hoạt động</span>
					}
				</dd>
			</dl>

			<form asp-action="DeleteConfirmed" asp-route-id="@Model.MaSanPham" method="post">
				<button type="submit" class="btn btn-danger">
					<i class="bi bi-trash"></i> Xóa
				</button>
				<a asp-action="Index" class="btn btn-secondary">
					<i class="bi bi-x-circle"></i> Hủy
				</a>
			</form>
		</div>
	</div>
</div>
