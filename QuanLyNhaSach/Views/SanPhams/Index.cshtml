@model IEnumerable<QuanLyNhaSach.Models.SanPham>

@{
	ViewData["Title"] = "Danh sách sản phẩm";
}

<div class="container mt-4">
	<div class="row mb-4">
		<div class="col-md-6">
			<h1>@ViewData["Title"]</h1>
		</div>
		<div class="col-md-6 text-end">
			<a asp-action="Create" class="btn btn-primary">
				<i class="bi bi-plus-circle"></i> Thêm sản phẩm mới
			</a>
		</div>
	</div>

	@if (Model.Any())
	{
		<div class="table-responsive">
			<table class="table table-striped table-hover">
				<thead class="table-dark">
					<tr>
						<th>Mã SP</th>
						<th>Tên sản phẩm</th>
						<th>Loại</th>
						<th>Giá bán</th>
						<th>Số lượng tồn</th>
						<th>Trạng thái</th>
						<th>Hành động</th>
					</tr>
				</thead>
				<tbody>
					@foreach (var item in Model)
					{
						<tr>
							<td>@item.MaSanPham</td>
							<td>@item.TenSanPham</td>
							<td>@item.LoaiSanPham</td>
							<td>@item.GiaBan.ToString("C")</td>
							<td>@item.SoLuongTon</td>
							<td>
								@if (item.TrangThai)
								{
									<span class="badge bg-success">Hoạt động</span>
								}
								else
								{
									<span class="badge bg-danger">Không hoạt động</span>
								}
							</td>
							<td>
								<a asp-action="Details" asp-route-id="@item.MaSanPham" class="btn btn-sm btn-info">
									<i class="bi bi-eye"></i> Chi tiết
								</a>
								<a asp-action="Edit" asp-route-id="@item.MaSanPham" class="btn btn-sm btn-warning">
									<i class="bi bi-pencil"></i> Sửa
								</a>
								<a asp-action="Delete" asp-route-id="@item.MaSanPham" class="btn btn-sm btn-danger">
									<i class="bi bi-trash"></i> Xóa
								</a>
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	}
	else
	{
		<div class="alert alert-info" role="alert">
			Không có sản phẩm nào. <a asp-action="Create">Thêm sản phẩm mới</a>
		</div>
	}
</div>
