@model ProductListViewModel
@{
    ViewData["Title"] = "Danh sách sách";
}

<section class="page-title">
    <p>BOOK CATALOG</p>
    <h1>Danh sách sách</h1>
</section>

<form class="search-box" asp-controller="SanPhams" asp-action="Index" method="get">
    <input name="keyword" value="@Model.Keyword" placeholder="Tìm sách theo tên hoặc mô tả..." />
    <select name="maDanhMuc">
        <option value="">Tất cả thể loại</option>
        @foreach (var cat in Model.DanhMucs)
        {
            if (Model.MaDanhMuc == cat.MaDanhMuc)
            {
                <option value="@cat.MaDanhMuc" selected>@cat.TenDanhMuc</option>
            }
            else
            {
                <option value="@cat.MaDanhMuc">@cat.TenDanhMuc</option>
            }
        }
    </select>
    <button type="submit">Lọc sách</button>
</form>

@if (!Model.SanPhams.Any())
{
    <div class="empty-state">Không tìm thấy sách phù hợp.</div>
}
else
{
    <div class="book-grid list-page">
        @foreach (var item in Model.SanPhams)
        {
            <partial name="_ProductCard" model="item" />
        }
    </div>
}
