@model RegisterViewModel
@{
    Layout = "_BlankLayout";
    ViewData["Title"] = "Đăng ký";
}
<style>
    .figma-canvas.auth-canvas{
        overflow: hidden;
        margin: 0 !important;
        padding: 0 !important;
        width: 100%;
        justify-content: center; /* Căn giữa theo chiều ngang */
        align-items: center; /* Căn giữa theo chiều dọc */
       
    }
    </style>
<div class="figma-canvas auth-canvas">
    <a class="figma-back" asp-controller="Home" asp-action="Index">‹</a>
    <section class="auth-figma-card register-card-size">
        <div class="text-center mb-4">
            <h1 class="auth-brand red-only">BOOKPORT</h1>
            <p>Tạo tài khoản mới ngay hôm nay</p>
        </div>
        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
            <div class="form-block icon-field">
                <label asp-for="HoTen">Họ và tên</label>
                <span>♙</span><input asp-for="HoTen" placeholder="Nguyễn Văn A" />
                <span asp-validation-for="HoTen" class="text-danger small validation-inline"></span>
            </div>
            <div class="form-block icon-field">
                <label asp-for="Email">Email</label>
                <span>✉</span><input asp-for="Email" placeholder="example@gmail.com" />
                <span asp-validation-for="Email" class="text-danger small validation-inline"></span>
            </div>
            <div class="form-block icon-field">
                <label asp-for="MatKhau">Mật khẩu</label>
                <span>▣</span><input asp-for="MatKhau" type="password" placeholder="Tối thiểu 6 ký tự" />
                <span asp-validation-for="MatKhau" class="text-danger small validation-inline"></span>
            </div>
            <div class="form-block icon-field">
                <label asp-for="XacNhanMatKhau">Xác nhận mật khẩu</label>
                <span>◇</span><input asp-for="XacNhanMatKhau" type="password" placeholder="Nhập lại mật khẩu" />
                <span asp-validation-for="XacNhanMatKhau" class="text-danger small validation-inline"></span>
            </div>
            <div class="form-block icon-field">
                <label asp-for="SoDienThoai">Số điện thoại</label>
                <span>☎</span><input asp-for="SoDienThoai" placeholder="0912345678" />
                <span asp-validation-for="SoDienThoai" class="text-danger small validation-inline"></span>
            </div>
            <div class="form-block icon-field">
                <label asp-for="DiaChi">Địa chỉ</label>
                <span>⌂</span><input asp-for="DiaChi" placeholder="Số nhà, tên đường" />
            </div>
            <label class="agree-line"><input type="checkbox" required /> Tôi đồng ý với điều khoản sử dụng của BOOKPORT.</label>
            <button class="auth-submit" type="submit">ĐĂNG KÝ</button>
            <p class="auth-bottom">Bạn đã có tài khoản? <a asp-action="Login">Đăng nhập ngay</a></p>
        </form>
    </section>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
