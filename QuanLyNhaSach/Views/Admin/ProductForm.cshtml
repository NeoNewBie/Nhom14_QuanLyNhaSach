@model SanPham
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = Model.MaSanPham == 0 ? "Thêm sách" : "Sửa sách";
}
<h1 class="admin-title">@ViewData["Title"]</h1>
<form asp-action="ProductForm" method="post" class="admin-card">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="MaSanPham" />
    <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
    <div class="row">
        <div class="col-md-8 mb-3">
            <label asp-for="TenSanPham" class="form-label">Tên sách</label>
            <input asp-for="TenSanPham" class="form-control" />
        </div>
        <div class="col-md-4 mb-3">
            <label asp-for="LoaiSanPham" class="form-label">Loại sản phẩm</label>
            <input asp-for="LoaiSanPham" class="form-control" />
        </div>
    </div>
    <div class="row">
        <div class="col-md-4 mb-3"><label class="form-label">Danh mục</label><select asp-for="MaDanhMuc" asp-items="ViewBag.DanhMucs" class="form-select"></select></div>
        <div class="col-md-4 mb-3"><label class="form-label">Tác giả</label><select asp-for="MaTacGia" asp-items="ViewBag.TacGias" class="form-select"><option value="">-- Chọn tác giả --</option></select></div>
        <div class="col-md-4 mb-3"><label class="form-label">Nhà xuất bản</label><select asp-for="MaNhaXuatBan" asp-items="ViewBag.NhaXuatBans" class="form-select"><option value="">-- Chọn NXB --</option></select></div>
    </div>
    <div class="row">
        <div class="col-md-3 mb-3"><label asp-for="GiaNhap" class="form-label">Giá nhập</label><input asp-for="GiaNhap" class="form-control" /></div>
        <div class="col-md-3 mb-3"><label asp-for="GiaBia" class="form-label">Giá bìa</label><input asp-for="GiaBia" class="form-control" /></div>
        <div class="col-md-3 mb-3"><label asp-for="GiaBan" class="form-label">Giá bán</label><input asp-for="GiaBan" class="form-control" /></div>
        <div class="col-md-3 mb-3"><label asp-for="SoLuongTon" class="form-label">Tồn kho</label><input asp-for="SoLuongTon" class="form-control" /></div>
    </div>
    <div class="mb-3"><label asp-for="AnhBia" class="form-label">Đường dẫn ảnh bìa</label><input asp-for="AnhBia" class="form-control" placeholder="/images/books/book01.svg" /></div>
    <div class="mb-3"><label asp-for="MoTa" class="form-label">Mô tả</label><textarea asp-for="MoTa" rows="5" class="form-control"></textarea></div>
    <div class="form-check mb-3"><input asp-for="TrangThai" class="form-check-input" /><label asp-for="TrangThai" class="form-check-label">Đang bán</label></div>
    <button class="btn btn-danger" type="submit">Lưu</button>
    <a class="btn btn-outline-secondary" asp-action="Products">Hủy</a>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
