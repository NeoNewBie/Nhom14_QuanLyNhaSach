@model SecurityViewModel
@{
    Layout = "_BlankLayout";
    ViewData["Title"] = "Bảo mật tài khoản";
}
<div class="figma-canvas user-canvas">
    <a class="figma-back" asp-controller="User" asp-action="Profile">‹</a>
    <section class="account-main-card single-card security-card">
        <h1>🛡 Bảo mật tài khoản</h1>
        <p class="text-muted">Đổi mật khẩu đăng nhập cho tài khoản BookPort.</p>
        <form asp-action="Security" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-2"></div>
            <div class="form-block"><label asp-for="MatKhauHienTai">Mật khẩu hiện tại</label><input asp-for="MatKhauHienTai" type="password" /><span asp-validation-for="MatKhauHienTai" class="text-danger small"></span></div>
            <div class="form-block"><label asp-for="MatKhauMoi">Mật khẩu mới</label><input asp-for="MatKhauMoi" type="password" /><span asp-validation-for="MatKhauMoi" class="text-danger small"></span></div>
            <div class="form-block"><label asp-for="XacNhanMatKhauMoi">Xác nhận mật khẩu mới</label><input asp-for="XacNhanMatKhauMoi" type="password" /><span asp-validation-for="XacNhanMatKhauMoi" class="text-danger small"></span></div>
            <button class="save-red-btn" type="submit">Cập nhật mật khẩu</button>
        </form>
    </section>
</div>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
