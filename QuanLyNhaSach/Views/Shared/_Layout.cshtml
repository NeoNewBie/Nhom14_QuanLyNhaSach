                <a asp-controller="Information" asp-action="Page" asp-route-slug="shipping">Shipping Policy</a>
                <a asp-controller="Information" asp-action="Page" asp-route-slug="returns">Returns & Refunds</a>
                <a asp-controller="Information" asp-action="Page" asp-route-slug="gift">Gift Card Balance</a>
                <a asp-controller="Information" asp-action="Page" asp-route-slug="help">Help Center</a>
            </div>
