                <a asp-controller="Home" asp-action="Index" asp-fragment="top-sellers">Best Sellers</a>
                <a asp-controller="Home" asp-action="Index" asp-fragment="new-releases">New Releases</a>
                <a asp-controller="Contact" asp-action="Index">Contact Us</a>
            </div>
            <div>
