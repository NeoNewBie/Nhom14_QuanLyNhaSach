@model SanPham
<div class="product-card figma-product-card" onclick="window.location.href='@Url.Action("Details", "SanPham", new { id = Model.MaSanPham })'">
    <a asp-controller="SanPham" asp-action="Details" asp-route-id="@Model.MaSanPham" class="product-image-wrap">
        <img class="cover-img" src="@Model.AnhBiaUrl" alt="@Model.TenSanPham" onerror="this.onerror=null;this.src='/images/books/placeholder.svg';" />
        @if (Model.NgayTao >= DateTime.Now.AddDays(-30))
        {
            <span class="badge-new">NEW</span>
        }
    </a>
    <div class="product-info">
        <a asp-controller="SanPham" asp-action="Details" asp-route-id="@Model.MaSanPham" class="product-title">@Model.TenSanPham</a>
        <div class="product-author">@(Model.TacGia?.TenTacGia ?? "Đang cập nhật")</div>
        <div class="product-bottom-row">
            <strong class="price">@Model.GiaBan.ToString("N0") đ</strong>
            <form asp-controller="GioHang" asp-action="Add" method="post" class="m-0" onclick="event.stopPropagation();">
                @Html.AntiForgeryToken()
                <input type="hidden" name="maSanPham" value="@Model.MaSanPham" />
                <input type="hidden" name="soLuong" value="1" />
                <button class="mini-cart-btn" type="submit" title="Thêm vào giỏ">＋</button>
            </form>
        </div>
    </div>
</div>
